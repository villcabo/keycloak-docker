# Alloy log shipper → external Loki. Copy to monitoring/.env and customize.
# Loki and Grafana are NOT deployed here; this only ships logs to your Loki.

# Stream labels
SYSTEM_NAME=keycloak
ENV_NAME=production
# HOST_NAME is auto-filled per node via a Swarm template ({{.Node.Hostname}}).

# External Loki push endpoint (HTTP API)
LOKI_REMOTE_URL=https://loki.internal/loki/api/v1/push
# Multi-tenant header X-Scope-OrgID
LOKI_TENANT=keycloak

# Basic auth (leave blank to disable)
LOKI_USERNAME=
LOKI_PASSWORD=

# Set true only if Loki uses a self-signed cert on an internal network
LOKI_TLS_INSECURE_SKIP_VERIFY=false
