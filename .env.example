# Keycloak Swarm cluster configuration.
# Copy to .env and customize. The .env is gitignored.

# External PostgreSQL — shared by every Keycloak node, must be reachable from
# all Swarm hosts. Keycloak stores state AND uses it for cluster discovery (jdbc-ping).
DATABASE_URL=jdbc:postgresql://192.168.0.10:5432/keycloak
DATABASE_USERNAME=keycloak
DATABASE_PASSWORD=change_me

# Bootstrap admin (Keycloak 26+ env names)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_me

# Public hostname. TLS terminates on an upstream LB/proxy; Traefik injects
# X-Forwarded-Proto=https so Keycloak builds correct https URLs.
KEYCLOAK_HOSTNAME=openid.sintesis.com.bo

# Keycloak image tag (overrides the 26.6.2 default in the stack files)
KEYCLOAK_IMAGE_VERSION=26.6.2
