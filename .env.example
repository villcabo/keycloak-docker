# Keycloak HA — single .env for all modes (compose, swarm, monitoring).
# Setup:  bash scripts/env-sync.sh
#
# SWARM ONLY — `docker stack deploy` does NOT read .env, so it won't interpolate the
# ${...} placeholders in the stack files unless you export the vars into the shell first:
#   set -a; . .env; set +a
# (Docker Compose reads .env by itself — no export needed there.)
#
# Uncommented = REQUIRED (you must set it). Commented = optional, shows the default.

# ────────────────────────────────────────────────────────────────────────────
# Keycloak

# Keycloak image tag. Run `kc.sh update-compatibility check` before minor/major bumps (UPGRADE.md).
#KEYCLOAK_IMAGE_VERSION=26.6.2

# REQUIRED — external PostgreSQL JDBC URL: jdbc:postgresql://<host>:<port>/<db>
DATABASE_URL=jdbc:postgresql://192.168.0.10:5432/keycloak
# REQUIRED — password of the keycloak DB user.
DATABASE_PASSWORD=change_me
# REQUIRED — bootstrap admin password.
KEYCLOAK_ADMIN_PASSWORD=change_me
# REQUIRED — public hostname (no scheme/port). Must match the nginx server_name.
KEYCLOAK_HOSTNAME=openid.example.com

# DB user for the keycloak database.
#DATABASE_USERNAME=keycloak
# Bootstrap admin username (first start only).
#KEYCLOAK_ADMIN=admin
# Replica count — SWARM ONLY (compose scales with `--scale keycloak=N`).
#KEYCLOAK_REPLICAS=3
# Root log level. Per-category override e.g. INFO,org.keycloak.events:debug to
# see auth events (successful logins log at DEBUG, errors at WARN).
#KC_LOG_LEVEL=INFO

# ────────────────────────────────────────────────────────────────────────────
# Clustering (JGroups)

# Bind interface for Infinispan. Per-mode default: swarm 10.* / compose 172.*.
# Set ONLY if your bridge subnet isn't 172.x (custom daemon.json address-pools) —
# a wrong value silently breaks clustering (view stays 1). Check the real subnet:
#   docker network inspect <project>_keycloak-net --format '{{range .IPAM.Config}}{{.Subnet}}{{end}}'
#JGROUPS_BIND_ADDR=match-address:10.200.*

# ────────────────────────────────────────────────────────────────────────────
# Traefik (edge load balancer)

# Public HTTP port on the host (the upstream nginx/LB proxies here). Change it if
# :80 is taken on the host.
#TRAEFIK_HTTP_PORT=80
# Dashboard/API. OFF by default. To enable: set this true AND deploy with the
# traefik-dashboard.yml overlay (see README). Diagnostic only — firewall it.
#TRAEFIK_API_INSECURE=false
# Host port for the dashboard — only used when the traefik-dashboard.yml overlay
# is applied.
#TRAEFIK_DASHBOARD_PORT=8080
# COMPOSE ONLY — chain the dashboard overlay so plain `docker compose up` includes
# it (no -f flags). Uncomment to enable the dashboard (also set TRAEFIK_API_INSECURE
# =true). Swarm ignores this: use `docker stack deploy -c ... -c traefik-dashboard.yml`.
#COMPOSE_FILE=docker-compose.yml:traefik-dashboard.yml

# ────────────────────────────────────────────────────────────────────────────
# Monitoring / Alloy → external Loki (optional)

# Grafana Alloy image tag.
#ALLOY_VERSION=v1.16.1

# REQUIRED only if you enable monitoring — Loki push endpoint (Loki/Grafana run elsewhere).
#LOKI_REMOTE_URL=https://loki.internal/loki/api/v1/push
# Stream label: logical system name (X-Scope-OrgID tenant = this, by convention).
#SYSTEM_NAME=keycloak
# Stream label: environment.
#ENV_NAME=production
# Stream label host. Swarm auto-fills it; compose needs it (or HOST_NAME=$(hostname)).
#HOST_NAME=my-host
# Loki multi-tenant header.
#LOKI_TENANT=keycloak
# Loki basic auth (blank = disabled).
#LOKI_USERNAME=
#LOKI_PASSWORD=
# Skip TLS verify — true only for a self-signed internal Loki.
#LOKI_TLS_INSECURE_SKIP_VERIFY=false
