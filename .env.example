# Keycloak HA cluster — environment variables.
# Covers BOTH deploy modes: Docker Compose (docker-compose.yml) and Docker Swarm
# (keycloak-stack.yml / keycloak-stack.single.yml) and monitoring (alloy-*.yml).
#
# Usage:
#   cp .env.example .env
#   # Edit .env with real values
#   set -a; . .env; set +a   # before docker compose or docker stack deploy
#
# Lines starting with '#' are comments. Uncomment (remove leading '#') to set a value.
# Secret fields use 'change_me' as placeholder — replace ALL of them before use.

# =============================================================================
# SECTION 1 — Keycloak core (used by BOTH docker-compose.yml AND swarm stack files)
# =============================================================================

# External PostgreSQL connection URL. Must be reachable from every host running
# Keycloak. Keycloak stores all state here AND uses it for cluster discovery (jdbc-ping).
# Format: jdbc:postgresql://<host>:<port>/<dbname>
# Used by: docker-compose.yml, keycloak-stack.yml, keycloak-stack.single.yml
DATABASE_URL=jdbc:postgresql://192.168.0.10:5432/keycloak

# PostgreSQL credentials for the Keycloak database user.
# Used by: docker-compose.yml, keycloak-stack.yml, keycloak-stack.single.yml
DATABASE_USERNAME=keycloak
DATABASE_PASSWORD=change_me

# Bootstrap admin account created on first start (Keycloak 26+ env names).
# Change or remove after initial setup — Keycloak removes the bootstrap admin
# after the first regular admin is created via the UI.
# Used by: docker-compose.yml, keycloak-stack.yml, keycloak-stack.single.yml
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_me

# Public hostname for Keycloak (no scheme, no port).
# TLS terminates on the upstream nginx; Traefik injects X-Forwarded-Proto=https
# so Keycloak builds correct https:// URLs. Must match the nginx server_name.
# Example: openid.example.com
# Used by: docker-compose.yml, keycloak-stack.yml, keycloak-stack.single.yml
KEYCLOAK_HOSTNAME=openid.example.com

# Keycloak image version tag. Overrides the default (26.6.2) in the stack files.
# Run `kc.sh update-compatibility check` before minor or major version bumps.
# See UPGRADE.md for upgrade procedure.
# Used by: docker-compose.yml, keycloak-stack.yml, keycloak-stack.single.yml
KEYCLOAK_IMAGE_VERSION=26.6.2

# =============================================================================
# SECTION 2 — JGroups / clustering
# =============================================================================

# JGroups bind address pattern for Infinispan cluster formation.
# Controls which network interface JGroups binds to for inter-node communication.
#
#   Swarm mode:   default = match-address:10.*   (overlay network, inter-host)
#   Compose mode: default = match-address:172.*  (bridge network, single-host)
#
# IMPORTANT — custom default-address-pools:
#   If your Docker daemon.json uses non-standard default-address-pools, your
#   bridge subnet may NOT be 172.x (e.g. it could be 10.200.x or 192.168.x).
#   Before first compose deploy, verify the actual bridge subnet:
#     docker network inspect <project>_keycloak-net --format '{{range .IPAM.Config}}{{.Subnet}}{{end}}'
#   If the result is NOT 172.x, set JGROUPS_BIND_ADDR explicitly to match:
#     JGROUPS_BIND_ADDR=match-address:10.200.*
#
#   Wrong value → JGroups registers an unreachable IP → cluster view stays (1).
#   Verify cluster formed: `select ip from jgroups_ping` + logs show ISPN000094 (N).
#
# Leave commented to use the per-mode default in the stack/compose files.
# Used by: docker-compose.yml, keycloak-stack.yml, keycloak-stack.single.yml
#JGROUPS_BIND_ADDR=match-address:172.*

# =============================================================================
# SECTION 3 — Monitoring / Alloy (log shipper to external Loki)
# =============================================================================

# Logical system name — used as the `system` label on all Loki log streams.
# Helps distinguish this Keycloak cluster from others in the same Loki instance.
# Default: keycloak
# Used by: monitoring/alloy-stack.yml, docker-compose.yml (profile monitoring)
SYSTEM_NAME=keycloak

# Deployment environment name — used as the `env` label on all Loki log streams.
# Examples: production, staging, dev
# Used by: monitoring/alloy-stack.yml, docker-compose.yml (profile monitoring)
ENV_NAME=production

# Host machine name — used as the `host` label on all Loki log streams.
#
#   Swarm mode:   auto-filled per node via {{.Node.Hostname}} template (no need to set).
#   Compose mode: REQUIRED — compose has no template engine. Set explicitly or use:
#                   HOST_NAME=$(hostname) in shell before running docker compose, OR
#                   add HOST_NAME=<your-hostname> to this .env file.
#
# Used by: docker-compose.yml (profile monitoring) (alloy-stack.yml uses Swarm template)
#HOST_NAME=my-host

# External Loki push endpoint (HTTP API). Required for log shipping.
# Loki and Grafana are NOT deployed in this repo — they run externally.
# Example: https://loki.internal/loki/api/v1/push
# Used by: monitoring/alloy-stack.yml, docker-compose.yml (profile monitoring)
LOKI_REMOTE_URL=https://loki.internal/loki/api/v1/push

# Multi-tenant header X-Scope-OrgID sent to Loki with every push request.
# Convention: tenant = system name. Leave as 'keycloak' if using a single-tenant Loki.
# Used by: monitoring/alloy-stack.yml, docker-compose.yml (profile monitoring)
LOKI_TENANT=keycloak

# Loki basic auth credentials. Leave blank to disable basic auth.
# Used by: monitoring/alloy-stack.yml, docker-compose.yml (profile monitoring)
LOKI_USERNAME=
LOKI_PASSWORD=

# Set to 'true' only if Loki uses a self-signed TLS certificate on an internal network.
# Default: false
# Used by: monitoring/alloy-stack.yml, docker-compose.yml (profile monitoring)
LOKI_TLS_INSECURE_SKIP_VERIFY=false
